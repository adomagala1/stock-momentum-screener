import requests
from bs4 import BeautifulSoup
import logging
from pymongo import MongoClient
from vaderSentiment.vaderSentiment import SentimentIntensityAnalyzer
import pandas as pd

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")

HEADERS = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/116.0.0.0 Safari/537.36"
}


# --- Funkcja scrapująca newsy z Yahoo Finance ---
def fetch_yahoo_news(ticker):
    url = f"https://finance.yahoo.com/quote/{ticker}?p={ticker}"
    response = requests.get(url, headers=HEADERS)
    response.raise_for_status()

    soup = BeautifulSoup(response.text, "html.parser")
    items = soup.find_all("li", class_="stream-item")

    if not items:
        logging.info(f"Nie znaleziono żadnych newsów dla {ticker}.")
        return []

    all_data = []
    for item in items:
        section = item.find("section", class_="container")
        if not section:
            continue

        # Nagłówek + link
        a_tag = section.find("a", class_="titles")
        if a_tag:
            headline = a_tag.get_text(strip=True)
            link = a_tag.get("href")
            if link.startswith("/"):
                link = "https://finance.yahoo.com" + link
        else:
            headline, link = None, None

        # Źródło + data
        publishing = section.find("div", class_="publishing")
        if publishing:
            parts = publishing.get_text(strip=True).split("•")
            source = parts[0].strip()
            date = parts[1].strip() if len(parts) > 1 else None
        else:
            source, date = None, None

        all_data.append({
            "ticker": ticker,
            "headline": headline,
            "link": link,
            "source": source,
            "date": date
        })

    logging.info(f"Pobrano {len(all_data)} newsów dla {ticker}.")
    return all_data


# --- Funkcja licząca sentyment ---
def add_sentiment(news_list):
    analyzer = SentimentIntensityAnalyzer()
    for news in news_list:
        if news["headline"]:
            news["sentiment"] = analyzer.polarity_scores(news["headline"])['compound']
        else:
            news["sentiment"] = 0
    return news_list


# --- Funkcja zapisująca do MongoDB ---
def save_to_mongo(news_list):
    if not news_list:
        return
    client = MongoClient("mongodb://localhost:27017/")
    db = client["stocks_db"]
    collection = db["news_for_investments"]
    collection.insert_many(news_list)
    logging.info(f"Wstawiono {len(news_list)} newsów do MongoDB")


# --- Główny workflow ---
if __name__ == "__main__":
    tickers = ["AAPL", "MSFT", "TSLA", "DLO"]  # przykładowe tickery
    all_news = []

    for ticker in tickers:
        try:
            news = fetch_yahoo_news(ticker)  # ✅ poprawione
            news = add_sentiment(news)
            all_news.extend(news)
        except Exception as e:
            logging.error(f"Błąd przy pobieraniu newsów dla {ticker}: {e}")

    save_to_mongo(all_news)

    # Podgląd
    if all_news:
        df = pd.DataFrame(all_news)
        print(df[['ticker', 'headline', 'sentiment', 'date', 'source']])
    else:
        logging.info("Brak newsów do wyświetlenia.")

    logging.info("get_news.py zakończony")
