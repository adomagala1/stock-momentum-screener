import glob
import logging
import os

logging.basicConfig(
    level=logging.INFO,
    filename="logs/helpers.log",
    format="%(asctime)s [%(levelname)s] %(message)s"
)


def get_exact_file(
        end_width: str,
        get_only_tickers: bool,
        with_filters: bool,
        stocks_data_day: str = None,
        stocks_data: bool = False,
        news_file: bool = False
) -> str:
    """
    Zwraca pełną ścieżkę do pliku CSV.

    Parametry:
    - end_width: końcówka pliku (np. "20250925")
    - get_only_tickers: czy pobrać tylko tickery
    - with_filters: czy używać filtrów
    - stocks_data_day: data w przypadku danych giełdowych
    - stocks_data: czy to dane giełdowe
    - news_file: czy to plik z newsami
    """
    # Wybór dnia
    if stocks_data:
        if not stocks_data_day:
            raise ValueError("Musisz podać 'stocks_data_day', gdy stocks_data=True")
        file_day = stocks_data_day
    else:
        file_day = end_width

    # Wybór sufiksu pliku
    filename_suffix = {
        (True, False): f"finviz_tickers_{file_day}.csv",
        (False, False): f"finviz_stocks_{file_day}.csv",
        (False, True): f"finviz_filtered_stocks_{file_day}.csv",
        (True, True): f"finviz_filtered_tickers_{file_day}.csv"
    }[(get_only_tickers, with_filters)]

    # Wybór folderu
    if stocks_data:
        folder = "data/stocks"
    elif news_file:
        folder = "data/news"
    else:
        folder = "data"

    # Ścieżka pliku
    pattern = os.path.join(folder, filename_suffix)
    abs_pattern = os.path.abspath(pattern)

    logging.info(f"Wzorzec ścieżki: {pattern}")
    logging.info(f"Pełna ścieżka: {abs_pattern}")

    files = glob.glob(pattern)
    if not files:
        raise FileNotFoundError(f"Brak pliku z końcówką '{file_day}' w ścieżce {abs_pattern}")

    return files[0]
